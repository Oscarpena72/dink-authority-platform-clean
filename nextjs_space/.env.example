# ============================================================
# Dink Authority Magazine — Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env with real credentials to version control.
# ============================================================

# ── Database (PostgreSQL) ──────────────────────────────────────
# Prisma connection string for your PostgreSQL database.
# Example: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/dink_authority?schema=public

# ── NextAuth.js ────────────────────────────────────────────────
# Secret used to encrypt JWT tokens and session cookies.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Base URL of your app (set automatically in production by Abacus AI)
# For local development:
# NEXTAUTH_URL=http://localhost:3000

# ── AWS S3 (File Uploads / Cloud Storage) ─────────────────────
# Used for uploading magazine PDFs, cover images, and media.
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_FOLDER_PREFIX=your-folder-prefix
AWS_PROFILE=default
# OR use access keys directly:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Abacus AI API (LLM for translations) ──────────────────────
# Used for real-time article translation (EN ↔ ES ↔ PT).
# Only needed if using the translation feature.
ABACUSAI_API_KEY=your-abacusai-api-key

# ── App Identification ─────────────────────────────────────────
WEB_APP_ID=your-web-app-id

# ── Notifications (Optional) ──────────────────────────────────
# ID for community correspondent registration notifications.
NOTIF_ID_COMMUNITY_CORRESPONDENT_REGISTRATION=your-notification-id
