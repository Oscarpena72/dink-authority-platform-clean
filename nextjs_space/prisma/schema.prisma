generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/dink_authority_magazine/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          String    @default("admin")
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  articles      Article[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Article {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  content      String
  excerpt      String?
  imageUrl     String?
  focalPointX  Float     @default(50)
  focalPointY  Float     @default(50)
  category     String    @default("news")
  status       String    @default("draft")
  isFeatured   Boolean   @default(false)
  isHeroStory  Boolean   @default(false)
  authorId     String?
  authorName   String?
  videoUrl          String?
  videoPosterImage  String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  author       User?     @relation(fields: [authorId], references: [id])

  @@index([status, publishedAt])
  @@index([category])
  @@index([slug])
}

model Event {
  id          String    @id @default(cuid())
  name        String
  description String?
  location    String
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  externalUrl String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDate])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  phoneNumber  String?
  source       String   @default("footer")
  subscribedAt DateTime @default(now())

  @@index([subscribedAt])
}

model Media {
  id               String   @id @default(cuid())
  fileName         String
  cloudStoragePath String?
  url              String
  altText          String?
  mimeType         String?
  size             Int?
  isPublic         Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@index([key])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model TournamentResult {
  id             String   @id @default(cuid())
  tournamentName String
  division       String
  winner         String
  runnerUp       String
  score          String?
  location       String?
  date           DateTime
  externalUrl    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

model ArticleTranslation {
  id        String   @id @default(cuid())
  articleId String
  locale    String
  title     String
  excerpt   String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, locale])
  @@index([articleId])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  category         String   @default("merchandise")
  price            Float
  shortDescription String?
  fullDescription  String?
  images           String[] @default([])
  stripePaymentLink String?
  buttonLabel      String   @default("Buy Now")
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  inventoryStatus  String   @default("in_stock")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([category])
}

model TipAuthor {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  photoUrl  String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tips      Tip[]

  @@index([slug])
}

model Tip {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?
  featuredImage   String?
  authorId        String
  author          TipAuthor  @relation(fields: [authorId], references: [id])
  publishDate     DateTime?
  category        String?
  content         String
  galleryImages   String     @default("[]")
  banner1Image    String?
  banner1Link     String?
  banner2Image    String?
  banner2Link     String?
  banner3Image    String?
  banner3Link     String?
  youtubeUrl        String?
  videoUrl          String?
  videoPosterImage  String?
  videoCtaText    String?
  videoCtaLink    String?
  status          String     @default("draft")
  language        String     @default("en")
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([authorId])
  @@index([status, publishDate])
  @@index([slug])
}

model Junior {
  id                String     @id @default(cuid())
  name              String
  title             String
  slug              String     @unique
  excerpt           String?
  country           String?
  age               Int?
  featuredImage     String?
  content           String
  galleryImages     String     @default("[]")
  banner2Image      String?
  banner2Link       String?
  banner3Image      String?
  banner3Link       String?
  instagramVideoUrl String?
  videoUrl          String?
  videoPosterImage  String?
  status            String     @default("draft")
  language          String     @default("en")
  publishDate       DateTime?
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status, publishDate])
  @@index([slug])
}

model CommunityCorrespondent {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  city          String
  state         String
  address       String?
  zipCode       String?
  phone         String?
  email         String
  facebookUrl   String?
  instagramUrl  String?
  tiktokUrl     String?
  message       String?
  status        String   @default("new")
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model MagazineEdition {
  id           String   @id @default(cuid())
  title        String
  issueNumber  String?
  coverUrl     String?
  description  String?
  pdfUrl       String?
  externalUrl  String?
  isCurrent    Boolean  @default(false)
  publishDate  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  pdfCloudPath String?
  pdfPageCount Int?
  slug         String?  @unique

  @@index([publishDate])
}
